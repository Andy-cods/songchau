# ═══════════════════════════════════════════════════════════════════════
# Song Châu ERP — backend/.env.example  (W4-04)
#
# Copy file này thành `.env` (cùng thư mục backend/) rồi điền giá trị THẬT.
# TUYỆT ĐỐI KHÔNG commit file `.env` thật (đã có trong .gitignore).
# Mọi giá trị dưới đây chỉ là VÍ DỤ/PLACEHOLDER — KHÔNG phải secret thật.
#
# Đọc thêm: docs/SECRETS_INVENTORY.md (secret nào lưu ở đâu, cách xoay vòng).
#
# Fail-fast: khi APP_ENV=production, app/core/config.py sẽ RAISE ngay lúc
# khởi động nếu thiếu 1 trong các biến đánh dấu [BẮT BUỘC khi production]
# hoặc nếu biến đó vẫn còn nguyên giá trị mẫu (chứa chữ "change-me").
# Khi APP_ENV=development (mặc định của file mẫu này), các kiểm tra đó được
# bỏ qua để không cản trở dev — nhưng backend vẫn có thể lỗi lúc GỌI tính
# năng cần biến đó (vd. gọi BQMS mà thiếu BQMS_PASSWORD).
# ═══════════════════════════════════════════════════════════════════════


# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# [BẮT BUỘC khi production] DATABASE_URL — HOẶC đủ bộ POSTGRES_USER +
# POSTGRES_PASSWORD + POSTGRES_DB (Settings tự ráp connection string nếu
# DATABASE_URL để trống, xem app/core/config.py:async_database_url).
POSTGRES_DB=songchau_erp
POSTGRES_USER=scadmin
# SECRET — mật khẩu Postgres thật. Không để trống khi production.
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
# SECRET — connection string đầy đủ (ưu tiên hơn POSTGRES_* nếu có giá trị).
# Dạng: postgresql+asyncpg://<user>:<password>@<host>:5432/<db>
DATABASE_URL=postgresql+asyncpg://scadmin:change-me-to-a-strong-db-password@postgres:5432/songchau_erp
# Kích thước pool kết nối async (asyncpg). Tuỳ chọn — mặc định 5/20 hợp lý
# cho VPS 4vCPU/8GB hiện tại; chỉ chỉnh nếu thấy nghẽn/kiệt pool.
DB_POOL_MIN=5
DB_POOL_MAX=20
# SECRET — dự phòng cho tính năng mã hoá dữ liệu tại app-layer (field-level
# encryption). Khai báo trong Settings nhưng CHƯA được dùng ở đâu trong code
# hiện tại (grep app/ không thấy import Fernet/encrypt/decrypt nào dùng biến
# này) — để trống hoặc điền placeholder, không ảnh hưởng vận hành hiện tại.
DB_ENCRYPTION_KEY=change-me-32-hex-chars-0123456789abcdef


# ─── Redis (cache + Procrastinate broker lock) ──────────────────────────
# Tuỳ chọn — có default khớp tên service Docker Compose "redis". Chỉ đổi
# nếu chạy Redis ở host/port khác (vd chạy backend ngoài Docker để dev).
REDIS_URL=redis://redis:6379/0


# ─── Auth (JWT) ──────────────────────────────────────────────────────────
# [BẮT BUỘC khi production] JWT_SECRET_KEY — SECRET. Dùng ký/verify access +
# refresh token. Yêu cầu tối thiểu 32 ký tự khi production (fail-fast sẽ
# chặn nếu ngắn hơn hoặc vẫn là giá trị mẫu này). Tạo bằng:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-string-aaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_ALGORITHM=HS256
# Access token sống ngắn (phút). Refresh token sống dài hơn (ngày).
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Cờ Secure của cookie refresh_token. True = chỉ gửi qua HTTPS (bắt buộc cho
# production thật). Đặt False CHỈ khi test local qua http:// thuần (không
# TLS) để trình duyệt vẫn nhận cookie.
COOKIE_SECURE=True


# ─── App ──────────────────────────────────────────────────────────────
# QUAN TRỌNG: mặc định của Settings (khi KHÔNG có .env / KHÔNG set env var)
# là APP_ENV=production (an toàn theo mặc định). File mẫu này đặt sẵn
# "development" để dev local không bị fail-fast chặn khởi động — nhớ đổi
# lại "production" khi deploy thật (VPS .env).
APP_ENV=development
# [BẮT BUỘC khi production] APP_URL — domain/IP public của hệ thống. Dùng
# để: (1) giới hạn CORS allow_origins (nếu để trống lúc production, CORS sẽ
# rơi về "*" — không an toàn khi allow_credentials=True); (2) build link
# tuyệt đối trong email/notification (app/tasks/notifications.py).
APP_URL=http://localhost:8000
DEBUG=False
# Mức log: DEBUG / INFO / WARNING / ERROR. Production nên để INFO trở lên.
LOG_LEVEL=INFO
# Ngưỡng (VNĐ) để PO cần thêm 1 cấp duyệt (workflow_engine.py). Đơn vị: đồng.
PO_APPROVAL_THRESHOLD=50000000
# Giới hạn dung lượng file upload (MB) — chặn ở RequestSizeLimitMiddleware.
MAX_UPLOAD_SIZE_MB=50


# ─── Feature Flags (behavior-change — cần Thang sign-off trước khi bật) ──
# Tất cả các cờ dưới đây mặc định FALSE/DRYRUN=TRUE để việc DEPLOY code mới
# không tự động đổi hành vi tài chính/dữ liệu. Chỉ đổi khi chủ hệ thống
# (Thang) đã duyệt.
#
# Bật auto-tạo công nợ phải thu (accounts_receivable) khi duyệt payment
# request liên kết sourcing order (Phase 3 event spine).
PHASE3_AUTO_AR_ENABLED=False
# Bật auto-tạo công nợ phải trả (accounts_payable) khi 1 procurement_delivery
# chuyển status='received'.
PROCUREMENT_AUTO_AP_ENABLED=False
# Bật tick định kỳ tự động chuyển trạng thái BQMS QT (V-round/D-N state
# machine). BQMS_STATE_TICK_DRYRUN=True => chỉ LOG dự kiến, KHÔNG ghi DB.
BQMS_STATE_TICK_ENABLED=False
BQMS_STATE_TICK_DRYRUN=True


# ─── Files ────────────────────────────────────────────────────────────
# Thư mục gốc lưu file đính kèm (ảnh, PDF, hồ sơ...) trên đĩa container/VPS.
FILES_BASE_PATH=/data/files
# Base URL public để build link tải file trả về cho FE (tuỳ chọn — để trống
# thì API không trả field download_url tuyệt đối).
FILES_BASE_URL=


# ─── Samsung BQMS (sec-bqms.com) — tuỳ chọn, chỉ cần cho tính năng scrape/
# push báo giá Samsung. Để trống thì các tác vụ liên quan BQMS sẽ báo lỗi
# khi CHẠY (không chặn khởi động app). ───────────────────────────────────
# SECRET
BQMS_USERNAME=
# SECRET
BQMS_PASSWORD=
BQMS_BASE_URL=https://www.sec-bqms.com


# ─── IMV / iMarketVietnam (imvmall.com) — tuỳ chọn, chỉ cần cho tính năng
# scrape RFQ/PO nhà cung cấp IMV. ────────────────────────────────────────
# SECRET
IMV_USER_ID=
# SECRET
IMV_PASSWORD=
IMV_BASE_URL=https://www.imvmall.com


# ─── Google Gemini — tuỳ chọn, chỉ cần cho tính năng OCR (app/api/v1/
# ocr_service.py). Để trống thì OCR trả lỗi rõ ràng, các phần khác của app
# không bị ảnh hưởng. ─────────────────────────────────────────────────────
# SECRET
GEMINI_API_KEY=


# ─── Microsoft 365 / Microsoft Graph — tuỳ chọn, chỉ cần cho: đồng bộ
# OneDrive (app/tasks/onedrive_sync.py, app/etl/onedrive_client.py), gửi
# email thông báo qua Graph (app/tasks/notifications.py,
# app/utils/email_sender.py). Để trống thì các luồng này tự tắt/no-op
# (có guard `if not all([...])`), app vẫn chạy bình thường. ──────────────
M365_TENANT_ID=
M365_CLIENT_ID=
# SECRET
M365_CLIENT_SECRET=
# ID của OneDrive/SharePoint drive dùng để đồng bộ file.
M365_DRIVE_ID=


# ─── File Browser / OneDrive Cache — khai báo trong Settings nhưng hiện
# CHƯA thấy được đọc ở đâu trong app/ (dự phòng cho tính năng cache local
# tương lai). Tuỳ chọn, không ảnh hưởng vận hành hiện tại. ────────────────
ONEDRIVE_CACHE_PATH=/data/files/onedrive-cache
ONEDRIVE_CACHE_MAX_GB=20


# ─── Services khác (đọc trực tiếp qua os.getenv trong code — KHÔNG khai
# báo trong app/core/config.py Settings, nhưng vẫn là biến env app dùng
# thật; liệt kê ở đây cho đủ, tất cả đều có default hợp lý nên tuỳ chọn) ──
# URL nội bộ tới service Gotenberg (convert PDF — docker-compose service
# "gotenberg", cổng 3000). Hầu hết code dùng hằng số nội bộ
# "http://gotenberg:3000" (app/services/gotenberg_service.py); riêng
# app/api/v1/invoice_management.py đọc qua biến này — chỉ đổi nếu đổi tên/
# host service Gotenberg trong docker-compose.
GOTENBERG_URL=http://gotenberg:3000
# URL frontend nội bộ — dùng để build link trong 1 số email hoá đơn
# (app/api/v1/invoice_management.py).
FRONTEND_URL=http://frontend:3000
# Thư mục lưu PDF hoá đơn xuất ra (invoice_management.py).
INVOICE_PDF_DIR=/app/files/invoices
# SECRET — access token Microsoft Graph dùng RIÊNG cho luồng gửi email hoá
# đơn (invoice_management.py:send_invoice_email) — khác cơ chế OAuth
# client-credentials của M365_CLIENT_SECRET ở trên. Để trống thì gửi email
# hoá đơn bị skip có log cảnh báo, không crash.
GRAPH_API_ACCESS_TOKEN=
# Email hiển thị là người gửi hoá đơn.
GRAPH_SENDER_EMAIL=accounting@songchau.com.vn
# Ngưỡng ngày để coi tỷ giá FX trong sourcing_pricing_engine là "cũ"/stale.
FX_STALENESS_DAYS=7
# Thư mục staging tải file OneDrive về trước khi xử lý (onedrive_sync.py).
ONEDRIVE_STAGING_PATH=/data/onedrive-staging
# Mốc ngày REG_DT sớm nhất mà scraper đấu thầu BQMS sẽ quét (lọc dữ liệu cũ
# không cần đồng bộ lại). Định dạng YYYY-MM-DD.
BQMS_SCRAPE_MIN_REG_DT=2026-05-12


# ─── Ghi chú: script vận hành (backend/scripts/*.py) ────────────────────
# Các script chạy tay một lần (import/seed/reconcile dữ liệu, đẩy file lên
# VPS...) đọc thêm 1 số biến env RIÊNG qua os.getenv, KHÔNG phải một phần
# cấu hình runtime của app (không cần đặt trong .env, thường export tạm khi
# chạy script): PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE,
# POSTGRES_DSN, VPS_HOST, VPS_USER, VPS_KEY, VPS_DEPLOY_ROOT,
# LOCAL_PIM_PATH, PIM_ENRICH_LOG_DIR, TEST_PO_NO. Xem từng script để biết
# default cụ thể.
