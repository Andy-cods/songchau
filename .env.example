# Copy this to .env and fill in real values
# NEVER commit .env to git

POSTGRES_DB=songchau_erp
POSTGRES_USER=scadmin
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://scadmin:CHANGE_ME@postgres:5432/songchau_erp
DB_ENCRYPTION_KEY=CHANGE_ME

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

APP_ENV=production
APP_URL=https://erp.songchau.vn
DEBUG=false
LOG_LEVEL=INFO
PO_APPROVAL_THRESHOLD=50000000
MAX_UPLOAD_SIZE_MB=50

FILES_BASE_PATH=/data/files
FILES_BASE_URL=https://erp.songchau.vn/files

BQMS_USERNAME=
BQMS_PASSWORD=
BQMS_BASE_URL=https://www.sec-bqms.com

GEMINI_API_KEY=

M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_DRIVE_ID=
